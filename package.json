{
  "name": "auto-skelly",
  "version": "1.0.0",
  "description": "Framework-agnostic skeleton loading placeholders. Auto-generates animated skeletons from your existing markup to improve perceived load time.",
  "license": "MIT",
  "author": "Alex Gordienko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexGordienko/Auto-Skelly.git"
  },
  "bugs": {
    "url": "https://github.com/AlexGordienko/Auto-Skelly/issues"
  },
  "homepage": "https://auto-skelly.alexgordienko.com",
  "keywords": [
    "skeleton",
    "skeleton-loader",
    "skeleton-screen",
    "placeholder",
    "shimmer",
    "loading",
    "spinner",
    "ux",
    "perceived-performance"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "unpkg": "./dist/auto-skelly.global.js",
  "jsdelivr": "./dist/auto-skelly.global.js",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "start": "npx serve docs",
    "build": "tsup && npm run copy:demo",
    "copy:demo": "cp dist/auto-skelly.global.js docs/auto-skelly.global.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "jsdom": "^27.0.1",
    "prettier": "^3.9.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
